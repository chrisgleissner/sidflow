node_modules/
.bun/
.playwright-browsers/
.DS_Store
*.log
coverage/
dist/
packages/*/dist/
packages/*/.tsbuildinfo
workspace/
!workspace/.gitkeep
test-workspace/
tmp
_codeql_detected_source_root

# Environment files (may contain secrets)
.env
.env.local
.env.production

# Test artifacts
packages/libsidplayfp-wasm/test-output.wav
test-results/validation-run*.txt
test-results/
!test-results/.last-run.json

# Preferences
.sidflow-preferences.json

# Derived artifacts (not committed)
data/sidflow.lance/

# Binary model artifacts (regenerated from training)
data/model/model.json
data/model/*.bin
data/model/*.pb

# Analysis
data/high-cpu-use/

# Build metadata (updated on each build, should not be committed)
data/wasm-build.json

# Test-generated audit logs (should not be committed)
data/audit/admin-actions.jsonl

# Manifests and canonical data ARE committed
!data/sidflow.lance.manifest.json
!data/classified/sample.jsonl
!data/feedback/**/*.jsonl

# Cache
data/cache

# Classification output files (generated during tests/runs)
data/classified/*.jsonl

# Training logs and model artifacts change on each build/test run
# Tests should use test-specific directories instead
data/training/*.jsonl

# Per-run classification lifecycle logs (generated during runs, not committed)
logs/
data/model/feature-stats.json
data/model/model-metadata.json
data/model/model/weights.bin

# Playlist storage (test artifacts, should not be committed)
data/playlists/

# Runtime job/rate-limit state (generated locally, should not be committed)
data/jobs/manifest.json
data/rate-limits/

# User data (contains password hashes, should not be committed)
data/users/

# Performance test results (generated, not the journey definitions)
performance/results/
performance/summary/
data/.sidflow-classify-temp.json

# Coverage reports (generated during test runs)
coverage-merged/

# Local installation directory (user-specific deployment configs)
local-install/

# Symlinked folders
c64commander
hvsc
.next/
data/exports/sidcorr-hvsc-full-sidcorr-1.sqlite
data/exports/sidcorr-hvsc-full-sidcorr-1.manifest.json
