#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME="${SIDFLOW_CLI_RUNTIME:-bun}"

case "${RUNTIME}" in
	bun)
		exec "${ROOT_DIR}/packages/sidflow-classify/src/cli.ts" "$@"
		;;
	node)
		DIST_CLI="${ROOT_DIR}/packages/sidflow-classify/dist/cli.js"
		if [[ ! -f "${DIST_CLI}" ]]; then
			printf 'sidflow-classify node runtime requires compiled output at %s\n' "${DIST_CLI}" >&2
			printf 'Run npm run build:quick or bun run build:quick first.\n' >&2
			exit 1
		fi
		exec node "${ROOT_DIR}/scripts/run-node-cli.mjs" "${DIST_CLI}" runClassifyCli "$@"
		;;
	*)
		printf 'Unsupported SIDFLOW_CLI_RUNTIME: %s\n' "${RUNTIME}" >&2
		exit 1
		;;
esac
